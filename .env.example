ANTHROPIC_API_KEY=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHANNEL_ID=
APIFY_API_KEY=                 # optional, for social trending
NEWSAPI_KEY=                   # optional
CLAUDE_MODEL=claude-sonnet-4-20250514   # Sonnet for extractor/synthesizer/earnings
HAIKU_MODEL=claude-haiku-4-5-20251001   # Haiku for scoring gate (cheap + fast)
OUTPUT_DIR=output              # directory for JSON output and dedup.sqlite
LOG_LEVEL=INFO
SCORE_THRESHOLD=6.0            # default item filter threshold (0-10)
DEDUP_TTL_HOURS=72             # sqlite dedup window in hours
