GEMINI_API_KEY=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHANNEL_ID=
APIFY_API_KEY=                 # optional, for social trending and deep article extraction
APIFY_ARTICLE_ACTOR=apify/website-content-crawler
NEWSAPI_KEY=                   # optional
GEMINI_MODEL=gemini-3.1-pro-preview       # Pro for extractor/synthesizer/earnings
GEMINI_FLASH_MODEL=gemini-3-flash-preview # Flash for scoring gate (cheap + fast)
GEMINI_REQUEST_TIMEOUT_MS=45000 # per Gemini request timeout; keep below Cloud Run job timeout
OUTPUT_DIR=output              # directory for JSON output and dedup.sqlite
LOG_LEVEL=INFO
SCORE_THRESHOLD=               # optional override of scoring/score_config.yaml `default` (7.2). Leave empty to use config.
MIN_BASE_SCORE_THRESHOLD=0.35  # cheap heuristic gate before Gemini scoring (0.0-1.0)
MIN_LEXICON_SCORE=3.0          # drop obvious low-signal domain matches before Gemini scoring
MAX_SCORING_ARTICLES=24        # cap Gemini Flash scoring calls per run
MAX_EXTRACTION_ARTICLES=8      # cap Gemini Pro extraction calls per run
MAX_DEEP_ARTICLES=3            # cap deep KOL/paper analysis calls per run
MIN_DEEP_WORDS=800             # public full-text minimum before deep chain runs
MAX_EARNINGS_FILINGS=2         # cap earnings filings processed per run
PIPELINE_TIMEOUT_SECONDS=540   # stop new work before Cloud Run's 600s task timeout
DEDUP_TTL_HOURS=72             # sqlite dedup window in hours
MAX_ITEMS_PER_DIGEST=6         # max items shown in Telegram digest
MIN_DIGEST_ITEMS=3             # minimum readable digest items; fallback summaries fill the gap
MAX_SUMMARY_CHARS=260          # max chars per item summary in Telegram digest
GITHUB_PAGES_URL=              # optional, e.g. https://yourname.github.io/tech-pulse

# Firestore-only retrieval memory for delivered digest/deep/earnings items.
MEMORY_ENABLED=1
MEMORY_BACKEND=firestore
GEMINI_EMBEDDING_MODEL=gemini-embedding-001
MEMORY_EMBEDDING_DIM=768
MEMORY_TOP_K=3
SEMANTIC_DUP_DISTANCE_THRESHOLD=0.12
SEMANTIC_DUP_DROP_ENABLED=0     # rollout default: add context/archive, but don't aggressively drop near-duplicates yet
MEMORY_TTL_DAYS=365

# Production state backend. auto uses sqlite locally and Firestore on Cloud Run.
STATE_BACKEND=auto
FIRESTORE_PROJECT_ID=          # optional; defaults to GCP project from application credentials
FIRESTORE_DATABASE=            # optional; leave empty for Firestore default database
FIRESTORE_COLLECTION_PREFIX=tech_pulse
