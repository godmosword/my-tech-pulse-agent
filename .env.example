GEMINI_API_KEY=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHANNEL_ID=
APIFY_API_KEY=                 # optional, for social trending and deep article extraction
APIFY_ARTICLE_ACTOR=apify/website-content-crawler
NEWSAPI_KEY=                   # optional
GEMINI_MODEL=gemini-3.1-pro-preview       # Pro for extractor/synthesizer/earnings
GEMINI_FLASH_MODEL=gemini-3-flash-preview # Flash for scoring gate (cheap + fast)
GEMINI_REQUEST_TIMEOUT_MS=45000 # per Gemini request timeout; keep below Cloud Run job timeout
# Flash JSON calls (scoring): omit thinking tokens so JSON body is less likely truncated (set 0 to restore LOW thinking).
GEMINI_DISABLE_THINKING_FOR_FLASH=1
REVIEWER_MAX_OUTPUT_TOKENS=1024  # Gemini Pro reviewer JSON; raise if logs show truncated output
OUTPUT_DIR=output              # directory for JSON output and dedup.sqlite
LOG_LEVEL=INFO
SCORE_THRESHOLD=               # optional override of scoring/score_config.yaml `default` (7.2). Leave empty to use config.
MIN_BASE_SCORE_THRESHOLD=0.35  # cheap heuristic gate before Gemini scoring (0.0-1.0)
MIN_LEXICON_SCORE=3.0          # drop obvious low-signal domain matches before Gemini scoring
MAX_SCORING_ARTICLES=24        # cap Gemini Flash scoring calls per run
MAX_UNSCORED_TAIL=3            # max scoring-failed articles merged into delivery pool (matches Telegram formatter default)
# Flash scoring output budget (truncated JSON → parse errors if too low)
SCORE_FLASH_OUTPUT_TOKENS=512
SCORE_FLASH_RETRY_OUTPUT_TOKENS=1024
MAX_EXTRACTION_ARTICLES=8      # cap Gemini Pro extraction calls per run
MAX_DEEP_ARTICLES=3            # cap deep KOL/paper analysis calls per run
MIN_DEEP_WORDS=800             # public full-text minimum before deep chain runs
MAX_EARNINGS_FILINGS=2         # cap earnings filings processed per run
PIPELINE_TIMEOUT_SECONDS=540   # stop new work before Cloud Run's 600s task timeout
DEDUP_TTL_HOURS=72             # sqlite dedup window in hours
MAX_ITEMS_PER_DIGEST=6         # max items shown in Telegram digest
# Telegram digest layout: v1 = canonical #科技脈搏 (📡 header / 🗞️ headline / 🧭 今日主線 / 📈 市場含義 / 🧠 深度洞察 / themed ⭐ blocks / footer). v2 = experimental numbered digest. Default v1 — omit or set v1 to lock this format.
DIGEST_FORMAT=v1
DIGEST_HEADER_TIMEZONE=Asia/Taipei   # IANA zone for 📡 / v2 header time (pipeline uses UTC internally)
MIN_DIGEST_ITEMS=3             # minimum readable digest items; fallback summaries fill the gap
ITEM_DIGEST_THEME_MIN_SUMMARIES=2   # min summaries before synthesizer runs (headline / themes / narrative); use 3 to save cost
MAX_SUMMARY_CHARS=340          # max chars per structured item body in Telegram digest (still under 4096 total message cap)
EXTRACTOR_MAX_INPUT_CHARS=6000 # article text slice sent to Gemini extraction (cost vs coverage tradeoff)
# Optional: fetch full page via Apify for top-K scored articles before extraction (same APIFY_API_KEY).
EXTRACTOR_FULLTEXT_TOP_K=0     # set e.g. 3 to enrich Top-K by score; 0 disables
EXTRACTOR_FULLTEXT_MIN_WORDS=120  # minimum words from Apify for enrich to replace article.content
EXTRACTOR_FULLTEXT_TIMEOUT_SECONDS=90  # Apify actor wait budget per enrich fetch
NARRATIVE_EXCERPT_MAX_CHARS=600 # Telegram narrative excerpt; sentence-boundary truncation

MIN_WHAT_HAPPENED_CHARS=45      # below this length after reviewer LLM check triggers one extraction retry (source-grounded)
GITHUB_PAGES_URL=              # optional, e.g. https://yourname.github.io/tech-pulse
TELEGRAM_CHUNK_DELAY_MS=500    # delay between digest chunks (ms); prevents rate limiting

# Firestore-only retrieval memory for delivered digest/deep/earnings items.
MEMORY_ENABLED=1
MEMORY_BACKEND=firestore
GEMINI_EMBEDDING_MODEL=gemini-embedding-001
MEMORY_EMBEDDING_DIM=768
MEMORY_TOP_K=3
SEMANTIC_DUP_DISTANCE_THRESHOLD=0.12
SEMANTIC_DUP_DROP_ENABLED=0     # rollout default: add context/archive, but don't aggressively drop near-duplicates yet
MEMORY_CONTEXT_MAX_DISTANCE=0.35  # only show 相關歷史 when nearest match is within this distance
SEMANTIC_PREFILTER_ENABLED=0      # set to 1 to drop same-batch semantic duplicates before LLM extraction
SEMANTIC_PREFILTER_THRESHOLD=0.85 # cosine similarity threshold for pre-extraction dedup (0.0–1.0)
MEMORY_TTL_DAYS=365

# Production state backend. auto uses sqlite locally and Firestore on Cloud Run.
STATE_BACKEND=auto
FIRESTORE_PROJECT_ID=          # optional; defaults to GCP project from application credentials
FIRESTORE_DATABASE=            # optional; leave empty for Firestore default database
FIRESTORE_COLLECTION_PREFIX=tech_pulse

# Firestore collection for Portal news integration (investment-ai-agent; read-only SA).
# Separate from FIRESTORE_PROJECT_ID above so the Portal side can point at this project/collection explicitly.
TECH_PULSE_FIRESTORE_COLLECTION=tech_pulse_memory_items
TECH_PULSE_FIRESTORE_PROJECT=<your-gcp-project-id>
