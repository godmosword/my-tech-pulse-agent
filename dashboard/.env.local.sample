# Tech Pulse Dashboard — .env.local 範本
# 用法：cp .env.local.sample .env.local，再補上 FINNHUB_API_KEY 與你的 Firestore / 認證值。
# ⚠️ 此 .sample 會被 commit 進 git，請勿在此填入真實密鑰。
#     下方已產的隨機 token 僅為「現成範例」，正式使用請各自重新產生。

# === Firestore（必填）===
# 服務帳號 JSON（raw 或 base64）。留空則改走本機 ADC：
#   gcloud auth application-default login
FIREBASE_SERVICE_ACCOUNT_JSON=
# 你的 GCP 專案 ID
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
# collection 前綴（pipeline 預設 tech_pulse）
FIRESTORE_COLLECTION_PREFIX=tech_pulse
# 直接指定 collection 全名（少用，覆蓋上面的前綴邏輯）
TECH_PULSE_FIRESTORE_COLLECTION=

# === 認證 / 存取控制 ===
# 全站 Basic Auth：兩個都留空＝關閉（本機開發用）
DASHBOARD_BASIC_AUTH_USER=
DASHBOARD_BASIC_AUTH_PASS=
# 公開讀模式：標題/摘要匿名可看、完整正文需 /login。本機可留 false
DASHBOARD_PUBLIC_READ=false
# tp_reader cookie 的 HMAC 金鑰（≥32 字元，開公開讀時必填）
# 已幫你產一組；正式環境請用 `openssl rand -hex 32` 重新產生
DASHBOARD_SESSION_SECRET=670e06f0155fb1e013d4bf29e4ebb8922033fa0546b39374e7073c31e82225b8

# === REST API（選填）===
# GET /api/v1/* 完整欄位的 Bearer token。關閉公開讀且要用 API 時才需要
API_READ_TOKEN=

# === 投資 / 報價 ===
# ⬇️ 唯一需要你自己填：去 https://finnhub.io 申請後貼上
FINNHUB_API_KEY=
FINNHUB_HTTP_TIMEOUT_SEC=10

# === Pipeline 整合 ===
# POST /api/revalidate 的共享密鑰，必須與 tech-pulse pipeline 端「同值」才能刷新 ISR
# 已幫你產一組範例；兩邊請填成相同的值
REVALIDATE_TOKEN=9cf6d4244a8f905032d02314cbdd50b125f4491c37f562b7

# === 顯示 ===
# 摘要時間顯示時區
DIGEST_HEADER_TIMEZONE=Asia/Taipei
# 正式部署的 canonical / sitemap / OG 網址（本機可留空）
NEXT_PUBLIC_SITE_URL=
