# --- Firestore ---
# Either supply a service account JSON directly (raw or base64) ...
FIREBASE_SERVICE_ACCOUNT_JSON=

# ... or rely on Application Default Credentials locally:
#   gcloud auth application-default login
# (FIREBASE_SERVICE_ACCOUNT_JSON empty → ADC path).

# Override the Firestore collection if the pipeline uses a non-default prefix.
# Default = "tech_pulse_memory_items" (FIRESTORE_COLLECTION_PREFIX + "_memory_items").
FIRESTORE_COLLECTION_PREFIX=tech_pulse
TECH_PULSE_FIRESTORE_COLLECTION=

# --- Auth ---
# Leave both empty to disable Basic Auth (local dev / preview deploys).
DASHBOARD_BASIC_AUTH_USER=
DASHBOARD_BASIC_AUTH_PASS=

# --- Pipeline integration ---
# Shared secret for POST /api/revalidate (set the same value in the
# tech-pulse pipeline so it can flush ISR after each run).
REVALIDATE_TOKEN=

# Display timezone for digest header timestamps (default Asia/Taipei).
DIGEST_HEADER_TIMEZONE=Asia/Taipei
